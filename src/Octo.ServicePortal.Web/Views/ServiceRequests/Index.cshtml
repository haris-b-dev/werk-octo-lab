@using Octo.ServicePortal.Application.ServiceRequests.ListServiceRequests
@model IReadOnlyList<ServiceRequestListItemDto>

@{
    ViewData["Title"] = "Service Requests";
}

<h1>Service Requests</h1>

<p>
    <a asp-controller="ServiceRequests" asp-action="Create" class="btn btn-primary">
        Creaate Service Request
    </a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No service requests found.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>Status</th>
                <th>Type</th>
                <th>Customer Id</th>
                <th>Machine Id</th>
                <th>Created At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var serviceRequest in Model)
            {
                <tr>
                    <td>@serviceRequest.Id</td>
                    <td>@serviceRequest.Titel</td>
                    <td>@serviceRequest.Status</td>
                    <td>@serviceRequest.Type</td>
                    <td>@serviceRequest.CompanyCustomerId</td>
                    <td>@serviceRequest.MachineId</td>
                    <td>@serviceRequest.CreatedAt.ToLocalTime().ToString("g")</td>
                </tr>
            }
        </tbody>
    </table>
}